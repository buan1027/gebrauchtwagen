meta {
  name: POST token falsches Passwort
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/token
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "username": "admin",
    "password": "falsch"
  }
}

assert {
  res.status: eq 401
}

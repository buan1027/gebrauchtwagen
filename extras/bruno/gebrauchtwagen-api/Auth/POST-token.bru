meta {
  name: POST token
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/token
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "username": "admin",
    "password": "p"
  }
}

assert {
  res.status: eq 200
  res.body.token: isString
  res.body.rollen: isArray
  res.body.rollen[0]: eq ADMIN
}

script:post-response {
  const body = res.getBody();
  bru.setEnvVar("accessToken", body.token);
}
